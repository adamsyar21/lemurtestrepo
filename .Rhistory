library(dplyr)
# Step 1: Make sure your points are in the correct order (RPT001, RPT002, etc.)
# so the polygon draws in the right sequence rather than a jumbled shape
camp.border <- camp.border %>%
arrange(as.numeric(gsub("RPT", "", name)))
# Step 2: Combine points into a single geometry, then cast to a polygon
camp_polygon <- camp.border %>%
st_combine() %>%      # merges all points into one MULTIPOINT geometry
st_cast("LINESTRING") %>%   # connects points in order into a line
st_cast("POLYGON")     # closes the line into a polygon
# Step 3: Wrap it back into a proper sf object with CRS preserved
camp_polygon <- st_sf(geometry = camp_polygon, crs = st_crs(camp.border))
first_point <- st_coordinates(camp.border)[1, ]
last_point <- st_coordinates(camp.border)[nrow(camp.border), ]
first_point
last_point
polygon2 <- st_transform(camp_polygon, st_crs(fixed_lemurdata_sf))
points_loc <- st_intersects(fixed_lemurdata_sf, polygon2, sparse = FALSE)
camp.border <- camp.border %>%
arrange(as.numeric(gsub("RPT", "", name)))
# Extract coordinates to check for consecutive duplicates
coords <- st_coordinates(camp.border)
# Keep only rows where the point differs from the previous one
keep <- c(TRUE, !(coords[-1,1] == coords[-nrow(coords),1] & coords[-1,2] == coords[-nrow(coords),2]))
camp.border <- camp.border[keep, ]
# Now try casting again
camp_polygon <- camp.border %>%
st_combine() %>%
st_cast("LINESTRING") %>%
st_cast("POLYGON")
first_point <- st_coordinates(camp.border)[1, ]
last_point <- st_coordinates(camp.border)[nrow(camp.border), ]
first_point
last_point
