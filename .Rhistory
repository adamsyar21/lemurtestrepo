tm_borders(col = "red")
library(tidyverse)
library(sf)
library(tmap)
library(adehabitatHR)
library(ggplot2)
library(gitcreds)
library(lubridate)
library(dplyr)
origina_data <- read_csv("/Users/adamsyar/Downloads/School/Dr. Valenta Research/Lemur Analysis/Data/marojejy waypoints 2009 2010.csv")
str(original_data)
fixed_lemurdata <- fixed_lemurdata %>%
rename(date.time = 'cmt')
st_layers("Marojejy2009_2010.gpx")
fixed_lemurdata <- st_read("Marojejy2009_2010.gpx", layer = "waypoints")
fixed_lemurdata <- fixed_lemurdata %>%
rename(date.time = 'cmt')
# Now taking that column and transforming it from a dmyhms into a ymdhms format.
fixed_lemurdata$date.time <- dmy_hms(fixed_lemurdata$date.time)
# Creating individual columns for longitude and latitude as that makes it easier for the sf stuff:
fixed_lemurdata$lon <- st_coordinates(fixed_lemurdata)[,1]
fixed_lemurdata$lat <- st_coordinates(fixed_lemurdata)[,2]
fixed_lemurdata_sf <- st_as_sf(fixed_lemurdata,
coords = c("lon", "lat"),
crs = 4326)
# Visual Check in tmap:
tmap_mode("view")
tm_basemap("Esri.WorldImagery") +
tm_shape(fixed_lemurdata_sf) +
tm_dots (fill = "yellow",
fill_alpha = 0.5)
camp_border <- st_read("camp 2 perimeter.gpx", layer = "route_points")
coords <- st_coordinates(camp_border)[, c("X", "Y")]
camp_polygon <- st_polygon(list(coords)) %>%
st_sfc(crs = st_crs(camp_border)) %>%
st_sf(geometry = .)
# Let's see if it worked in tmap.
tmap_mode("view")
tm_basemap("Esri.WorldImagery")
tm_shape(camp_polygon) +
tm_borders(col = "yellow")
coords <- st_coordinates(camp_border)[, c("X", "Y")]
# Find any duplicated coordinates anywhere in the set (not just consecutive)
dup_rows <- duplicated(coords) | duplicated(coords, fromLast = TRUE)
# See which points are duplicated
coords[dup_rows, ]
which(dup_rows)
coords_clean <- coords[!duplicated(coords), ]
# Close the ring
closed_coords <- rbind(coords_clean, coords_clean[1, ])
camp_polygon <- st_polygon(list(closed_coords)) %>%
st_sfc(crs = st_crs(camp_border)) %>%
st_sf(geometry = .)
tmap_mode("view")
tm_basemap("Esri.WorldImagery") +
tm_shape(camp_polygon) +
tm_borders(col = "red", lwd = 2)
polygon <- st_transform(camp_polygon, st_crs(fixed_lemurdata_sf))
points_loc <- st_intersects(fixed_lemurdata_sf, camp_polygon, sparse = FALSE)
points_out <- fixed_lemurdata_sf[rowSums(points_loc) == 0, ]
# That seems to have worked, let's try the whole thing now.
# Plotting Points with Base Camp Removed ----------------------------------
tmap_mode("view")
tm_basemap("Esri.WorldImagery") +
tm_shape(points_out) +
tm_dots (fill = "yellow") +
tm_basemap("Esri.WorldImagery") +
tm_shape(camp_polygon) +
tm_borders(col = "red")
# Good stuff me, that actually looks really good!
