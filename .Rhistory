coords <- st_coordinates(camp_border)[, c("X", "Y")]
# Find any duplicated coordinates anywhere in the set (not just consecutive)
dup_rows <- duplicated(coords) | duplicated(coords, fromLast = TRUE)
# See which points are duplicated
coords[dup_rows, ]
coords_clean <- coords[!duplicated(coords), ]
# Close the ring
closed_coords <- rbind(coords_clean, coords_clean[1, ])
# Build the polygon
camp_polygon <- st_polygon(list(closed_coords)) %>%
st_sfc(crs = st_crs(camp_border)) %>%
st_sf(geometry = .)
tm_basemap("Esri.WorldImagery") +
tm_shape(camp_polygon) +
tm_borders(col = "red", lwd = 2)
