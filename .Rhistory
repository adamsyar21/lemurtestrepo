keep <- c(TRUE, !(coords[-1,1] == coords[-nrow(coords),1] & coords[-1,2] == coords[-nrow(coords),2]))
coords <- coords[keep, ]
closed_coords <- rbind(coords, coords[1, ])
camp_polygon <- st_polygon(list(closed_coords)) %>%
st_sfc(crs = st_crs(camp_border)) %>%
st_sf(geometry = .)
polygon2 <- st_transform(camp_polygon, st_crs(fixed_lemurdata_sf))
